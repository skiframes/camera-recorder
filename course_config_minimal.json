{
  "version": 1,
  "course_name": "Minimal Track Setup",
  "camera": {
    "type": "reolink",
    "ip": "192.168.0.101",
    "stream_profile": "h264Preview_01_sub",
    "frame_width": 1920,
    "frame_height": 1080
  },
  "model": {
    "path": "yolov8n.pt",
